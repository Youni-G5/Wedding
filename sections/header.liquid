{% comment %}
  sections/header.liquid
  - Transparent sur hero (homepage) → tout en blanc
  - Opaque (scrollé ou autres pages)  → tout en noir/foncé
  Aucune variable de couleur exposée — géré automatiquement par le CSS
{% endcomment %}

{%- assign nav_links       = linklists[section.settings.menu].links -%}
{%- assign nav_links_right = linklists[section.settings.menu_right].links -%}

{%- assign is_homepage = false -%}
{%- if template.name == 'index' -%}
  {%- assign is_homepage = true -%}
{%- endif -%}

<link rel="preload" href="{{ 'section-header.css' | asset_url }}" as="style">
<link rel="stylesheet" href="{{ 'section-header.css' | asset_url }}">

<style>
  .site-header__logo-img {
    width: {{ section.settings.logo_width }}px;
  }
</style>

<header
  class="site-header{% if section.settings.enable_sticky %} site-header--sticky{% endif %}{% if is_homepage and section.settings.transparent_on_hero %} site-header--over-hero{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="header"
  data-transparent="{% if is_homepage and section.settings.transparent_on_hero %}true{% else %}false{% endif %}"
>
  <div class="site-header__inner">

    {%- comment %} Menu gauche {%- endcomment %}
    <ul class="site-header__nav site-header__nav--left" role="list">
      {%- for link in nav_links -%}
        <li>
          <a
            href="{{ link.url }}"
            class="site-header__link{% if link.active %} is-active{% endif %}"
            {% if link.active %}aria-current="page"{% endif %}
          >{{ link.title }}</a>
        </li>
      {%- endfor -%}
    </ul>

    {%- comment %} Logo centré {%- endcomment %}
    <div class="site-header__logo">
      <a href="{{ routes.root_url }}" class="site-header__logo-link" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 400 }}"
            alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
            width="{{ section.settings.logo_width }}"
            height="auto"
            loading="eager"
            class="site-header__logo-img"
          >
        {%- else -%}
          <span class="site-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    {%- comment %} Zone droite : menu + CTA {%- endcomment %}
    <div class="site-header__right">
      {%- if section.settings.menu_right != blank and nav_links_right.size > 0 -%}
        <ul class="site-header__nav site-header__nav--right" role="list">
          {%- for link in nav_links_right -%}
            <li>
              <a
                href="{{ link.url }}"
                class="site-header__link{% if link.active %} is-active{% endif %}"
                {% if link.active %}aria-current="page"{% endif %}
              >{{ link.title }}</a>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.show_cta -%}
        <a
          href="{{ section.settings.cta_url }}"
          class="site-header__cta"
          {% if section.settings.cta_url == blank %}aria-disabled="true"{% endif %}
        >{{- section.settings.cta_label | escape -}}</a>
      {%- endif -%}
    </div>

    {%- comment %} Burger mobile {%- endcomment %}
    <button
      class="site-header__burger"
      aria-expanded="false"
      aria-controls="mobile-menu-{{ section.id }}"
      aria-label="{{ 'accessibility.menu_open' | t }}"
      data-burger
    >
      <span class="site-header__burger-line"></span>
      <span class="site-header__burger-line"></span>
      <span class="site-header__burger-line"></span>
    </button>
  </div>
</header>

<div id="mobile-menu-{{ section.id }}" class="mobile-menu" aria-hidden="true" data-mobile-menu>
  <div class="mobile-menu__inner">
    <button class="mobile-menu__close" aria-label="{{ 'accessibility.menu_close' | t }}" data-close-menu>
      {% render 'icon', icon: 'close' %}
    </button>
    <span class="mobile-menu__brand">{{ shop.name }}</span>
    <ul class="mobile-menu__list" role="list">
      {%- for link in nav_links -%}
        <li><a href="{{ link.url }}" class="mobile-menu__link{% if link.active %} is-active{% endif %}" {% if link.active %}aria-current="page"{% endif %}>{{ link.title }}</a></li>
      {%- endfor -%}
      {%- for link in nav_links_right -%}
        <li><a href="{{ link.url }}" class="mobile-menu__link{% if link.active %} is-active{% endif %}" {% if link.active %}aria-current="page"{% endif %}>{{ link.title }}</a></li>
      {%- endfor -%}
    </ul>
    {%- if section.settings.show_cta -%}
      <a href="{{ section.settings.cta_url }}" class="mobile-menu__cta">{{- section.settings.cta_label | escape -}}</a>
    {%- endif -%}
  </div>
</div>
<div class="mobile-menu__backdrop" data-backdrop aria-hidden="true"></div>

<script src="{{ 'section-header.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Header",
  "tag": "div",
  "class": "section-header-wrapper",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Largeur du logo",
      "default": 160
    },
    {
      "type": "header",
      "content": "Navigation gauche"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu gauche",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Navigation droite"
    },
    {
      "type": "link_list",
      "id": "menu_right",
      "label": "Menu droite (optionnel)"
    },
    {
      "type": "header",
      "content": "Bouton CTA"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Afficher le bouton \"Nous contacter\"",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texte du bouton",
      "default": "Nous contacter"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Lien du bouton"
    },
    {
      "type": "header",
      "content": "Options"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "Header fixe au scroll",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "transparent_on_hero",
      "label": "Transparent sur le hero (page d'accueil)",
      "default": true
    }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
