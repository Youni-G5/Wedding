{% comment %}
  sections/header.liquid
  Nav bar seule — logo toujours centré
  Le hero est une section séparée
{% endcomment %}

{%- assign nav_links = linklists[section.settings.menu].links -%}

<header
  class="site-header{% if section.settings.enable_sticky %} site-header--sticky{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="header"
>
  <div class="site-header__inner">

    {%- comment %} Liens gauche {%- endcomment %}
    <ul class="site-header__nav site-header__nav--left" role="list">
      {%- assign left_links = nav_links | slice: 0, 3 -%}
      {%- for link in left_links -%}
        <li>
          <a
            href="{{ link.url }}"
            class="site-header__link{% if link.active %} is-active{% endif %}"
            {% if link.active %}aria-current="page"{% endif %}
          >{{ link.title }}</a>
        </li>
      {%- endfor -%}
    </ul>

    {%- comment %} Logo centré en absolu {%- endcomment %}
    <div class="site-header__logo">
      <a href="{{ routes.root_url }}" class="site-header__logo-link" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 400 }}"
            alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
            width="{{ section.settings.logo_width }}"
            height="auto"
            loading="eager"
            class="site-header__logo-img"
          >
        {%- else -%}
          <span class="site-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    {%- comment %} Liens droite + utilitaires {%- endcomment %}
    <ul class="site-header__nav site-header__nav--right" role="list">
      {%- assign right_links = nav_links | slice: 3, 10 -%}
      {%- for link in right_links -%}
        <li>
          <a
            href="{{ link.url }}"
            class="site-header__link{% if link.active %} is-active{% endif %}"
            {% if link.active %}aria-current="page"{% endif %}
          >{{ link.title }}</a>
        </li>
      {%- endfor -%}
      {%- if section.settings.show_cart_icon -%}
        <li>
          <a
            href="{{ routes.cart_url }}"
            class="site-header__link site-header__link--cart"
            aria-label="{{ 'sections.header.cart' | t }}{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}"
          >
            <span class="site-header__cart-label">Panier</span>
            {%- if cart.item_count > 0 -%}
              <span class="site-header__cart-badge" aria-hidden="true">{{ cart.item_count }}</span>
            {%- endif -%}
          </a>
        </li>
      {%- endif -%}
    </ul>

    {%- comment %} Burger mobile {%- endcomment %}
    <button
      class="site-header__burger"
      aria-expanded="false"
      aria-controls="mobile-menu-{{ section.id }}"
      aria-label="{{ 'accessibility.menu_open' | t }}"
      data-burger
    >
      <span class="site-header__burger-line"></span>
      <span class="site-header__burger-line"></span>
      <span class="site-header__burger-line"></span>
    </button>

  </div>
</header>

{%- comment %} Menu mobile {%- endcomment %}
<div
  id="mobile-menu-{{ section.id }}"
  class="mobile-menu"
  aria-hidden="true"
  data-mobile-menu
>
  <div class="mobile-menu__inner">
    <button
      class="mobile-menu__close"
      aria-label="{{ 'accessibility.menu_close' | t }}"
      data-close-menu
    >
      {% render 'icon', icon: 'close' %}
    </button>
    <span class="mobile-menu__brand">{{ shop.name }}</span>
    <ul class="mobile-menu__list" role="list">
      {%- for link in nav_links -%}
        <li>
          <a
            href="{{ link.url }}"
            class="mobile-menu__link{% if link.active %} is-active{% endif %}"
            {% if link.active %}aria-current="page"{% endif %}
          >{{ link.title }}</a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>
<div class="mobile-menu__backdrop" data-backdrop aria-hidden="true"></div>

{{ 'section-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-header.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Header",
  "tag": "div",
  "class": "section-header-wrapper",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 160
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_cart_icon",
      "label": "Afficher le lien panier",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "Header fixe au scroll",
      "default": true
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Fond du header",
      "default": "#241a26"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Couleur du texte",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_hover",
      "label": "Couleur hover",
      "default": "#ebdceb"
    },
    {
      "type": "color",
      "id": "color_border",
      "label": "Bordure bas",
      "default": "#3a2c3e"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
