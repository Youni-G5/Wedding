{% comment %} sections/main-search.liquid {% endcomment %}
<section class="search" id="shopify-section-{{ section.id }}">
  <div class="container">
    <h1>{{ 'general.search.title' | t }}</h1>
    <form action="/search" method="get" role="search">
      <input type="hidden" name="type" value="product">
      <label for="search-input">{{ 'general.search.placeholder' | t }}</label>
      <input type="search" id="search-input" name="q" value="{{ search.terms | escape }}" autocomplete="off">
      <button type="submit" class="btn btn--primary">{{ 'general.search.submit' | t }}</button>
    </form>
    {%- if search.performed -%}
      {%- if search.results_count == 0 -%}
        <p>{{ 'general.search.no_results' | t: terms: search.terms }}</p>
      {%- else -%}
        <ul role="list">
          {%- for result in search.results -%}
            <li><a href="{{ result.url }}">{{ result.title }}</a></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Search",
  "settings": [],
  "presets": []
}
{% endschema %}
