{% comment %} sections/main-blog.liquid {% endcomment %}
<section class="blog" id="shopify-section-{{ section.id }}">
  <div class="container">
    <h1>{{ blog.title }}</h1>
    <ul class="blog__articles" role="list">
      {%- for article in blog.articles -%}
        <li>
          <a href="{{ article.url }}">{{ article.title }}</a>
          <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: format: 'month_day_year' }}</time>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Blog",
  "settings": [],
  "presets": []
}
{% endschema %}
