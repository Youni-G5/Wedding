{% comment %}
  sections/footer.liquid
  Wedding Theme — Shopify 2.0
  Couleurs injectées en inline <style> (Liquid non parsé dans assets/)
{% endcomment %}

{%- liquid
  assign footer_links = linklists[section.settings.menu].links
  assign legal_links  = linklists[section.settings.legal_menu].links
-%}

<style>
  #shopify-section-{{ section.id }} .site-footer {
    --sf-bg:           {{ section.settings.color_bg }};
    --sf-bg-legal:     {{ section.settings.color_bg_legal }};
    --sf-text:         {{ section.settings.color_text }};
    --sf-text-muted:   {{ section.settings.color_text_muted }};
    --sf-divider:      {{ section.settings.color_divider }};
    --sf-btn-bg:       {{ section.settings.color_btn_bg }};
    --sf-btn-text:     {{ section.settings.color_btn_text }};
    --sf-input-border: {{ section.settings.color_input_border }};
    --sf-logo-width:   {{ section.settings.logo_width }}px;
  }
</style>

<footer class="site-footer" id="shopify-section-{{ section.id }}" data-section-type="footer">

  {%- comment %} ── ZONE PRINCIPALE ── {%- endcomment %}
  <div class="site-footer__main">
    <div class="site-footer__container">

      {%- comment %} Colonne gauche : logo + nav 4 cols + socials {%- endcomment %}
      <div class="site-footer__left">

        {%- comment %} LOGO {%- endcomment %}
        <a href="{{ routes.root_url }}" class="site-footer__logo-link" aria-label="{{ shop.name }}">
          {%- if section.settings.logo != blank -%}
            <img
              src="{{ section.settings.logo | image_url: width: 300 }}"
              alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
              width="{{ section.settings.logo_width }}"
              height="auto"
              loading="lazy"
              class="site-footer__logo-img"
            >
          {%- else -%}
            <span class="site-footer__logo-text">{{ shop.name }}<span class="site-footer__logo-dot">.</span></span>
          {%- endif -%}
        </a>

        {%- comment %} NAV 4 colonnes {%- endcomment %}
        {%- if footer_links.size > 0 -%}
          <nav class="site-footer__nav" aria-label="Footer navigation">
            <ul class="site-footer__nav-list" role="list">
              {%- for link in footer_links -%}
                <li class="site-footer__nav-item">
                  <a href="{{ link.url }}" class="site-footer__nav-link">{{ link.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </nav>
        {%- endif -%}

        {%- comment %} ICÔNES SOCIALES {%- endcomment %}
        <ul class="site-footer__socials" role="list" aria-label="Réseaux sociaux">
          {%- if section.settings.social_facebook != blank -%}
            <li>
              <a href="{{ section.settings.social_facebook }}" class="site-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
              </a>
            </li>
          {%- endif -%}
          {%- if section.settings.social_instagram != blank -%}
            <li>
              <a href="{{ section.settings.social_instagram }}" class="site-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor" stroke="none"/></svg>
              </a>
            </li>
          {%- endif -%}
          {%- if section.settings.social_twitter != blank -%}
            <li>
              <a href="{{ section.settings.social_twitter }}" class="site-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="X / Twitter">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>
              </a>
            </li>
          {%- endif -%}
          {%- if section.settings.social_pinterest != blank -%}
            <li>
              <a href="{{ section.settings.social_pinterest }}" class="site-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Pinterest">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.236 2.636 7.855 6.356 9.312-.088-.791-.167-2.005.035-2.868.181-.78 1.172-4.97 1.172-4.97s-.299-.598-.299-1.482c0-1.388.806-2.428 1.808-2.428.852 0 1.265.64 1.265 1.408 0 .858-.546 2.14-.828 3.33-.236.995.499 1.806 1.476 1.806 1.772 0 3.135-1.866 3.135-4.561 0-2.386-1.715-4.052-4.163-4.052-2.834 0-4.498 2.126-4.498 4.322 0 .856.33 1.773.741 2.275a.3.3 0 01.069.285c-.076.311-.244.995-.277 1.134-.044.183-.146.222-.337.134-1.249-.581-2.03-2.407-2.03-3.874 0-3.154 2.292-6.052 6.608-6.052 3.469 0 6.165 2.473 6.165 5.776 0 3.447-2.173 6.22-5.19 6.22-1.013 0-1.966-.527-2.292-1.148l-.623 2.378c-.226.869-.835 1.958-1.244 2.621.937.29 1.931.446 2.962.446C17.523 22 22 17.523 22 12S17.523 2 12 2z"/></svg>
              </a>
            </li>
          {%- endif -%}
          {%- if section.settings.social_youtube != blank -%}
            <li>
              <a href="{{ section.settings.social_youtube }}" class="site-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 001.46 6.42 29 29 0 001 12a29 29 0 00.46 5.58 2.78 2.78 0 001.95 1.965C5.12 20 12 20 12 20s6.88 0 8.59-.455a2.78 2.78 0 001.95-1.965A29 29 0 0023 12a29 29 0 00-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg>
              </a>
            </li>
          {%- endif -%}
          {%- if section.settings.social_tiktok != blank -%}
            <li>
              <a href="{{ section.settings.social_tiktok }}" class="site-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.28 6.28 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.79 1.52V6.75a4.85 4.85 0 01-1.02-.06z"/></svg>
              </a>
            </li>
          {%- endif -%}
        </ul>

      </div>

      {%- comment %} Colonne droite : newsletter {%- endcomment %}
      {%- if section.settings.show_newsletter -%}
        <div class="site-footer__right">
          <p class="site-footer__newsletter-title">{{ section.settings.newsletter_title }}</p>
          {%- form 'customer', class: 'site-footer__newsletter-form' -%}
            {%- if form.errors -%}
              <p class="site-footer__form-error" role="alert">{{ form.errors | default_errors }}</p>
            {%- endif -%}
            {%- if form.posted_successfully? -%}
              <p class="site-footer__form-success" role="status">{{ 'sections.footer.newsletter_success' | t }}</p>
            {%- else -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <div class="site-footer__newsletter-row">
                <label for="footer-email-{{ section.id }}" class="sr-only">{{ 'sections.footer.email_placeholder' | t }}</label>
                <input
                  type="email"
                  id="footer-email-{{ section.id }}"
                  name="contact[email]"
                  class="site-footer__email-input"
                  placeholder="{{ 'sections.footer.email_placeholder' | t }}"
                  required
                  autocomplete="email"
                >
                <button type="submit" class="site-footer__subscribe-btn">
                  {{ 'sections.footer.subscribe' | t }}
                </button>
              </div>
              <div class="site-footer__newsletter-consent">
                <input
                  type="checkbox"
                  id="footer-consent-{{ section.id }}"
                  name="contact[newsletter_consent]"
                  class="site-footer__consent-checkbox"
                >
                <label for="footer-consent-{{ section.id }}" class="site-footer__consent-label">
                  {{ section.settings.newsletter_consent }}
                </label>
              </div>
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}

    </div>
  </div>

  {%- comment %} ── ZONE LÉGALE ── {%- endcomment %}
  <div class="site-footer__legal">
    <div class="site-footer__container">
      <ul class="site-footer__legal-list" role="list">
        {%- for link in legal_links -%}
          <li class="site-footer__legal-item">
            <a href="{{ link.url }}" class="site-footer__legal-link">{{ link.title }}</a>
          </li>
        {%- endfor -%}
        {%- if legal_links.size == 0 -%}
          <li class="site-footer__legal-item">
            <span class="site-footer__legal-link">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</span>
          </li>
        {%- endif -%}
      </ul>
    </div>
  </div>

</footer>

{{ 'section-footer.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "Footer",
  "tag": "div",
  "class": "section-footer-wrapper",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (laissez vide pour afficher le nom du shop)"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 250,
      "step": 10,
      "unit": "px",
      "label": "Largeur du logo",
      "default": 140
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu footer",
      "default": "footer"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Menu liens légaux",
      "info": "Créez un menu 'footer-legal' dans Shopify Admin"
    },
    {
      "type": "header",
      "content": "Réseaux sociaux"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "X / Twitter"
    },
    {
      "type": "url",
      "id": "social_pinterest",
      "label": "Pinterest"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Afficher la newsletter",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Titre newsletter",
      "default": "Get the freshest news"
    },
    {
      "type": "text",
      "id": "newsletter_consent",
      "label": "Texte consentement",
      "default": "By checking the box, you agree that you are at least 16 years of age."
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Fond du footer",
      "default": "#1a3a35"
    },
    {
      "type": "color",
      "id": "color_bg_legal",
      "label": "Fond zone légale",
      "default": "#152e29"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Couleur texte",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_text_muted",
      "label": "Texte secondaire",
      "default": "#a8c4be"
    },
    {
      "type": "color",
      "id": "color_divider",
      "label": "Couleur séparateur",
      "default": "#2d5048"
    },
    {
      "type": "color",
      "id": "color_input_border",
      "label": "Bordure input email",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_btn_bg",
      "label": "Fond bouton Subscribe",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_btn_text",
      "label": "Texte bouton Subscribe",
      "default": "#1a3a35"
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
